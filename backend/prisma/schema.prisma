generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  SUPERVISOR
  FINANCIAL_ADMIN
}

enum RequestType {
  REIMBURSEMENT
  TRAVEL_ADVANCE
  TRAVEL_REIMBURSEMENT
}

enum RequestStatus {
  DRAFT
  SUBMITTED
  SUPERVISOR_APPROVED
  SUPERVISOR_REJECTED
  FINANCE_APPROVED
  FINANCE_REJECTED
  PAID
}

enum ApprovalAction {
  APPROVE
  REJECT
  REQUEST_CHANGES
  PAID
}

enum ApprovalStage {
  SUPERVISOR
  FINANCE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  jobPosition  String?
  phone        String?
  extension    String?
  address      String?
  role         Role     @default(USER)
  supervisorId String?
  supervisor   User?    @relation("SupervisorUsers", fields: [supervisorId], references: [id])
  subordinates User[]   @relation("SupervisorUsers")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  requests  Request[]
  approvals Approval[]
  sessions  Session[]
  accounts  SupervisorAccount[]
}

model SupervisorAccount {
  id            String   @id @default(uuid())
  supervisorId  String
  supervisor    User     @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  accountNumber String
  label         String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  approvals Approval[]

  @@unique([supervisorId, accountNumber])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Request {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  type        RequestType
  status      RequestStatus @default(DRAFT)
  title       String
  description String?
  submittedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  reimbursement       ReimbursementDetail?
  travelAdvance       TravelAdvanceDetail?
  travelReimbursement TravelReimbursementDetail?
  documents           Document[]
  approvals           Approval[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

model ReimbursementDetail {
  id        String              @id @default(uuid())
  requestId String              @unique
  request   Request             @relation(fields: [requestId], references: [id], onDelete: Cascade)
  items     ReimbursementItem[]
}

model ReimbursementItem {
  id          String              @id @default(uuid())
  detailId    String
  detail      ReimbursementDetail @relation(fields: [detailId], references: [id], onDelete: Cascade)
  description String
  amount      Decimal             @db.Decimal(12, 2)
  date        DateTime
  vendor      String?
  notes       String?
  documents   Document[]
}

model TravelAdvanceDetail {
  id              String              @id @default(uuid())
  requestId       String              @unique
  request         Request             @relation(fields: [requestId], references: [id], onDelete: Cascade)
  destination     String
  purpose         String
  departureDate   DateTime
  returnDate      DateTime
  estimatedAmount Decimal             @db.Decimal(12, 2)
  items           TravelAdvanceItem[]
}

model TravelAdvanceItem {
  id       String              @id @default(uuid())
  detailId String
  detail   TravelAdvanceDetail @relation(fields: [detailId], references: [id], onDelete: Cascade)
  category String
  amount   Decimal             @db.Decimal(12, 2)
  notes    String?
}

model TravelReimbursementDetail {
  id               String              @id @default(uuid())
  requestId        String              @unique
  request          Request             @relation(fields: [requestId], references: [id], onDelete: Cascade)
  destination      String
  purpose          String
  departureDate    DateTime
  returnDate       DateTime
  totalAmount      Decimal             @db.Decimal(12, 2)
  advanceRequestId String?
  items            TravelExpenseItem[]
}

model TravelExpenseItem {
  id       String                    @id @default(uuid())
  detailId String
  detail   TravelReimbursementDetail @relation(fields: [detailId], references: [id], onDelete: Cascade)
  date     DateTime
  category String
  amount   Decimal                   @db.Decimal(12, 2)
  vendor   String?
  notes    String?
}

model Document {
  id                  String             @id @default(uuid())
  requestId           String
  request             Request            @relation(fields: [requestId], references: [id], onDelete: Cascade)
  reimbursementItemId String?
  reimbursementItem   ReimbursementItem? @relation(fields: [reimbursementItemId], references: [id], onDelete: SetNull)
  filename            String
  s3Key               String
  contentType         String
  sizeBytes           Int
  uploadedAt          DateTime           @default(now())
  uploadedBy          String

  @@index([requestId])
}

model Approval {
  id        String             @id @default(uuid())
  requestId String
  request   Request            @relation(fields: [requestId], references: [id])
  actorId   String
  actor     User               @relation(fields: [actorId], references: [id])
  action    ApprovalAction
  stage     ApprovalStage
  comment   String?
  accountId String?
  account   SupervisorAccount? @relation(fields: [accountId], references: [id])
  createdAt DateTime           @default(now())

  @@index([requestId])
  @@index([actorId])
}
