{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run -A --watch main.ts",
    "start": "deno run -A main.ts",
    "db:generate": "deno run -A npm:prisma@^7 generate",
    "db:migrate": "deno run -A npm:prisma@^7 migrate dev",
    "db:migrate:deploy": "deno run -A npm:prisma@^7 migrate deploy",
    "db:push": "deno run -A npm:prisma@^7 db push",
    "test": "deno test -A --env-file=.env.test"
  },
  "imports": {
    "hono": "npm:hono@^4",
    "hono/logger": "npm:hono@^4/logger",
    "hono/cookie": "npm:hono@^4/cookie",
    "hono/http-exception": "npm:hono@^4/http-exception",
    "@prisma/adapter-pg": "npm:@prisma/adapter-pg@^7",
    "@prisma/client": "npm:@prisma/client@^7",
    "jose": "npm:jose@^6",
    "@node-rs/argon2": "npm:@node-rs/argon2@^2",
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3",
    "@aws-sdk/s3-request-presigner": "npm:@aws-sdk/s3-request-presigner@^3",
    "zod": "npm:zod@^3"
  }
}
